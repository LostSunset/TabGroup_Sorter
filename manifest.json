{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "2.0.0",
  "description": "__MSG_appDescription__",
  "default_locale": "zh_TW",
  "permissions": [
    "tabGroups",
    "tabs",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "sort-groups": {
      "suggested_key": { "default": "Alt+S" },
      "description": "__MSG_cmdSort__"
    },
    "collapse-all": {
      "suggested_key": { "default": "Alt+C" },
      "description": "__MSG_cmdCollapse__"
    },
    "expand-all": {
      "suggested_key": { "default": "Alt+E" },
      "description": "__MSG_cmdExpand__"
    },
    "auto-group": {
      "suggested_key": { "default": "Alt+G" },
      "description": "__MSG_cmdAutoGroup__"
    }
  }
}
